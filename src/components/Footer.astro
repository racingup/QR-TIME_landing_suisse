<footer class="relative z-10 border-t border-ink-100/80 mt-10">
  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-14">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10">
      <div>
        <a href="#top" class="flex items-center gap-2 font-semibold tracking-tight mb-3" aria-label="qrtime.ch">
          <img src="/logo.png" alt="qrtime.ch" class="h-9 w-auto" onerror="this.onerror=null; this.src='/logo.svg';" />
        </a>
        <p class="text-sm text-ink-500 leading-relaxed max-w-xs">
          Pointage numérique suisse. QR + validation de position conforme à la LPD.
          Bureau, mission, terrain.
        </p>
      </div>
      <div>
        <h4 class="text-xs uppercase tracking-[0.18em] font-semibold text-ink-500 mb-4">Produit</h4>
        <ul class="space-y-2 text-sm text-ink-700">
          <li><a href="#fonctionnalites" class="hover:text-ink-900 transition">Fonctionnalités</a></li>
          <li><a href="#tarifs" class="hover:text-ink-900 transition">Tarifs</a></li>
          <li><a href="#securite" class="hover:text-ink-900 transition">Sécurité</a></li>
          <li><a href="#faq" class="hover:text-ink-900 transition">FAQ</a></li>
        </ul>
      </div>
      <div>
