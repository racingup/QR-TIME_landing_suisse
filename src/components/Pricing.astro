---
---
<section id="tarifs" class="section">
  <div class="max-w-3xl mb-14">
    <div class="eyebrow mb-4">Tarifs</div>
    <h2 class="font-display text-display-lg font-semibold text-ink-900 mb-4">
      Deux modèles. <span class="text-ink-400">Votre choix, pas le nôtre.</span>
    </h2>
    <p class="text-lg text-ink-600 leading-relaxed">
      Que vous préfériez la maîtrise totale ou la simplicité du cloud, QRtime s'adapte.
      Pas d'options cachées, pas de module premium : tout est inclus.
    </p>
  </div>

  <div class="grid lg:grid-cols-2 gap-5">
    <!-- Cloud -->
    <div class="glass-strong rounded-3xl p-8 sm:p-10 relative">
      <div class="absolute top-6 right-6 inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-swiss/10 text-swiss text-xs font-semibold tracking-wide uppercase">
        <span class="w-1.5 h-1.5 rounded-full bg-swiss"></span>
        Populaire
      </div>
      <div class="mb-2 text-sm font-medium text-ink-500">Cloud · Swiss Hosting</div>
      <div class="flex items-baseline gap-2 mb-2">
        <span class="font-display text-5xl font-semibold text-ink-900">3 CHF</span>
        <span class="text-ink-500">/ utilisateur / mois</span>
      </div>
      <p class="text-sm text-ink-500 mb-8">Facturé mensuellement. Sans engagement.</p>
      <ul class="space-y-3 mb-10">
        <li class="flex gap-3 text-ink-700"><svg class="w-5 h-5 text-brand flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4 10-10"/></svg>Hébergement 100% Suisse chez AlpiVault</li>
        <li class="flex gap-3 text-ink-700"><svg class="w-5 h-5 text-brand flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4 10-10"/></svg>Mises à jour automatiques</li>
        <li class="flex gap-3 text-ink-700"><svg class="w-5 h-5 text-brand flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4 10-10"/></svg>Sauvegardes quotidiennes chiffrées</li>
        <li class="flex gap-3 text-ink-700"><svg class="w-5 h-5 text-brand flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4 10-10"/></svg>Support email &amp; téléphone</li>
        <li class="flex gap-3 text-ink-700"><svg class="w-5 h-5 text-brand flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4 10-10"/></svg>Déploiement en 5 minutes</li>
        <li class="flex gap-3 text-ink-700"><svg class="w-5 h-5 text-brand flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4 10-10"/></svg>Utilisateurs illimités, multi-sites</li>
        <li class="flex gap-3 text-ink-700"><svg class="w-5 h-5 text-brand flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4 10-10"/></svg>SLA 99,9%</li>
      </ul>
      <a href="#contact" class="btn-primary w-full">Démarrer un essai 30 jours</a>
    </div>

    <!-- On-premise -->
    <div class="glass rounded-3xl p-8 sm:p-10 relative border-ink-200/80">
      <div class="mb-2 text-sm font-medium text-ink-500">On-Premise · Paiement unique</div>
      <div class="flex items-baseline gap-2 mb-2">
        <span class="font-display text-5xl font-semibold text-ink-900">15 000 CHF</span>
      </div>
      <p class="text-sm text-ink-500 mb-8">Installation incluse. Maintenance optionnelle.</p>
      <ul class="space-y-3 mb-10">
        <li class="flex gap-3 text-ink-700"><svg class="w-5 h-5 text-brand flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4 10-10"/></svg>Installation sur vos serveurs</li>
        <li class="flex gap-3 text-ink-700"><svg class="w-5 h-5 text-brand flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4 10-10"/></svg>Vos données restent chez vous</li>
        <li class="flex gap-3 text-ink-700"><svg class="w-5 h-5 text-brand flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4 10-10"/></svg>Code source documenté</li>
        <li class="flex gap-3 text-ink-700"><svg class="w-5 h-5 text-brand flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4 10-10"/></svg>Formation équipe IT (1 jour)</li>
        <li class="flex gap-3 text-ink-700"><svg class="w-5 h-5 text-brand flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4 10-10"/></svg>Maintenance annuelle : 2 500 CHF (optionnel)</li>
        <li class="flex gap-3 text-ink-700"><svg class="w-5 h-5 text-brand flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4 10-10"/></svg>Licence illimitée, à vie</li>
        <li class="flex gap-3 text-ink-700"><svg class="w-5 h-5 text-brand flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4 10-10"/></svg>Souveraineté totale</li>
      </ul>
      <a href="#contact" class="btn-secondary w-full">Parler à un expert</a>
    </div>
  </div>

  <!-- TCO comparator -->
  <div class="mt-10 glass-strong rounded-3xl p-6 sm:p-8">
    <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
      <div>
        <p class="text-sm text-ink-500 mb-1">Comparateur TCO sur 3 ans</p>
        <h3 class="font-semibold text-ink-900">Quelle offre est la plus économique pour moi ?</h3>
      </div>
      <div class="text-right">
        <p class="text-xs text-ink-500">Collaborateurs</p>
        <p class="font-display text-3xl font-semibold text-ink-900" id="tco-users">50</p>
      </div>
    </div>
    <input
      id="tco-slider"
      type="range"
      min="5"
      max="800"
      value="50"
      step="5"
      class="w-full h-2 bg-ink-100 rounded-full appearance-none cursor-pointer accent-brand"
    />
    <div class="grid sm:grid-cols-2 gap-4 mt-6">
      <div class="rounded-2xl border border-ink-100 p-5 bg-white/60">
        <p class="text-xs uppercase tracking-wider text-ink-500 mb-2">Cloud · 3 ans</p>
        <p class="font-display text-2xl font-semibold text-ink-900"><span id="tco-cloud">5 400</span> CHF</p>
      </div>
      <div class="rounded-2xl border border-ink-100 p-5 bg-white/60">
        <p class="text-xs uppercase tracking-wider text-ink-500 mb-2">On-Premise · 3 ans</p>
        <p class="font-display text-2xl font-semibold text-ink-900"><span id="tco-onprem">22 500</span> CHF</p>
      </div>
    </div>
    <p class="text-sm text-ink-500 mt-4" id="tco-advice">
      Pour 50 collaborateurs, le Cloud est plus économique. Le seuil de bascule se situe autour de 420 utilisateurs sur 3 ans.
    </p>
  </div>
</section>

<script>
  const slider = document.getElementById('tco-slider') as HTMLInputElement | null;
  const usersEl = document.getElementById('tco-users');
  const cloudEl = document.getElementById('tco-cloud');
  const onpremEl = document.getElementById('tco-onprem');
  const adviceEl = document.getElementById('tco-advice');
  const fmt = (n: number) => new Intl.NumberFormat('fr-CH').format(Math.round(n));
  function update() {
    if (!slider) return;
    const n = parseInt(slider.value, 10);
    const cloud = n * 3 * 36;
    const onprem = 15000 + 2500 * 3;
    usersEl && (usersEl.textContent = String(n));
    cloudEl && (cloudEl.textContent = fmt(cloud));
    onpremEl && (onpremEl.textContent = fmt(onprem));
    if (adviceEl) {
      adviceEl.textContent = cloud < onprem
        ? `Pour ${n} collaborateurs, le Cloud reste plus économique (écart : ${fmt(onprem - cloud)} CHF sur 3 ans).`
        : `Pour ${n} collaborateurs, l'On-Premise devient plus économique (économie : ${fmt(cloud - onprem)} CHF sur 3 ans).`;
    }
  }
  slider?.addEventListener('input', update);
  update();
</script>
