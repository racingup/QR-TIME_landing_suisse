          <li><a href="#contact" class="hover:text-ink-900 transition">Contact</a></li>
          <li><a href="https://alpivault.ch" class="hover:text-ink-900 transition">Hébergement AlpiVault</a></li>
          <li><span class="text-ink-400">Blog (bientôt)</span></li>
        </ul>
      </div>
      <div>
        <h4 class="text-xs uppercase tracking-[0.18em] font-semibold text-ink-500 mb-4">Légal</h4>
        <ul class="space-y-2 text-sm text-ink-700">
          <li><a href="#" class="hover:text-ink-900 transition">Conditions générales</a></li>
          <li><a href="#" class="hover:text-ink-900 transition">Politique de confidentialité</a></li>
          <li><a href="#" class="hover:text-ink-900 transition">Protection des données (nLPD)</a></li>
          <li><a href="#" class="hover:text-ink-900 transition">Mentions légales</a></li>
        </ul>
