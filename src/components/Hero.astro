---
---
<section id="top" class="section pt-14 sm:pt-20">
  <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
    <div class="lg:col-span-7">
      <div class="eyebrow mb-6">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-swiss"></span>
        Pointage numérique · 100% Swiss Hosting
      </div>
      <h1 class="font-display text-display-xl font-semibold text-ink-900 mb-6">
        Le pointage qui <span class="text-brand">prouve la présence</span>.
        <span class="block text-ink-500 font-normal mt-2 text-[0.7em]">Au bureau, en mission, sur le terrain.</span>
      </h1>
      <p class="text-lg text-ink-600 max-w-xl mb-8 leading-relaxed">
        QRtime combine QR code physique et validation par géolocalisation — proportionnée et
        conforme à la LPD — pour un pointage infalsifiable. Une seule solution pour vos équipes
        sédentaires, itinérantes et en déplacement. Hébergée en Suisse, chez AlpiVault.
      </p>
      <div class="flex flex-wrap items-center gap-3 mb-8">
        <a href="#contact" class="btn-primary">
          Demander une démo
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="#tarifs" class="btn-secondary">Essayer le cloud — 3 CHF / utilisateur</a>
      </div>
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-ink-500">
        <span class="inline-flex items-center gap-2">🇨🇭 Hébergement Suisse</span>
        <span class="inline-flex items-center gap-2">🔒 Conforme LPD &amp; nLPD</span>
        <span class="inline-flex items-center gap-2">⚡ Installation en 48h</span>
      </div>
    </div>

    <div class="lg:col-span-5">
      <div class="relative">
        <div class="glass-strong rounded-3xl p-6 sm:p-8 relative z-10">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-swiss/80"></div>
              <div class="w-2 h-2 rounded-full bg-ink-300"></div>
              <div class="w-2 h-2 rounded-full bg-ink-300"></div>
            </div>
            <span class="text-xs text-ink-400 font-mono">qrtime.ch/scan</span>
          </div>
          <div class="rounded-2xl bg-ink-900 p-6 text-center mb-5 relative overflow-hidden">
            <div class="inline-flex items-center justify-center w-32 h-32 rounded-xl bg-white p-3">
              <svg viewBox="0 0 100 100" class="w-full h-full" fill="#0D0F14">
                <rect x="0" y="0" width="30" height="30"/><rect x="5" y="5" width="20" height="20" fill="#fff"/><rect x="10" y="10" width="10" height="10"/>
                <rect x="70" y="0" width="30" height="30"/><rect x="75" y="5" width="20" height="20" fill="#fff"/><rect x="80" y="10" width="10" height="10"/>
                <rect x="0" y="70" width="30" height="30"/><rect x="5" y="75" width="20" height="20" fill="#fff"/><rect x="10" y="80" width="10" height="10"/>
                <rect x="40" y="10" width="5" height="5"/><rect x="50" y="10" width="10" height="5"/><rect x="40" y="20" width="15" height="5"/>
                <rect x="40" y="35" width="5" height="5"/><rect x="55" y="35" width="10" height="5"/><rect x="40" y="45" width="20" height="5"/>
                <rect x="40" y="55" width="5" height="5"/><rect x="50" y="55" width="5" height="5"/><rect x="60" y="55" width="5" height="5"/>
                <rect x="40" y="65" width="15" height="5"/><rect x="65" y="35" width="5" height="20"/>
                <rect x="45" y="75" width="10" height="5"/><rect x="65" y="75" width="5" height="5"/><rect x="75" y="45" width="5" height="5"/>
                <rect x="85" y="40" width="5" height="10"/><rect x="70" y="85" width="5" height="5"/><rect x="85" y="85" width="10" height="5"/>
              </svg>
            </div>
            <p class="text-white/80 text-xs mt-4 tracking-wider">SIÈGE LAUSANNE</p>
          </div>
          <div class="space-y-3">
            <div class="flex items-center justify-between text-sm">
              <span class="text-ink-500">Distance du site</span>
              <span class="font-mono font-medium text-ink-900">12 m</span>
            </div>
            <div class="flex items-center justify-between text-sm">
              <span class="text-ink-500">Rayon autorisé</span>
              <span class="font-mono font-medium text-ink-900">30 m</span>
            </div>
            <div class="h-px bg-ink-100"></div>
            <div class="flex items-center justify-between">
              <span class="inline-flex items-center gap-2 text-sm font-medium text-ink-900">
                <span class="w-2 h-2 rounded-full bg-accent"></span>
                Pointage validé
              </span>
              <span class="text-xs text-ink-400 font-mono">08:59</span>
            </div>
          </div>
        </div>
        <div class="glass rounded-2xl p-4 absolute -bottom-6 -left-6 z-20 hidden sm:block">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-xl bg-brand text-white flex items-center justify-center text-sm font-semibold">AM</div>
            <div>
              <p class="text-xs text-ink-400">Alice M. · mission client</p>
              <p class="text-sm font-medium text-ink-900">Genève → validée</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
