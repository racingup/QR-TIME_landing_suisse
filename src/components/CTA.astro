---
---
<section id="contact" class="section">
  <div class="grid lg:grid-cols-2 gap-10 items-start">
    <div>
      <div class="eyebrow mb-4">Contact</div>
      <h2 class="font-display text-display-lg font-semibold text-ink-900 mb-5">
        Prêt à arrêter de perdre du temps <span class="text-ink-400">sur le temps ?</span>
      </h2>
      <p class="text-lg text-ink-600 leading-relaxed mb-8 max-w-lg">
        En 15 minutes, on vous montre QRtime sur votre cas d'usage réel. Sans blabla commercial.
      </p>
      <ul class="space-y-4">
        <li class="flex gap-3 text-ink-700">
          <span class="w-8 h-8 rounded-full bg-ink-900 text-white flex items-center justify-center flex-shrink-0 text-sm">✓</span>
          Démo live sur votre site pilote
        </li>
        <li class="flex gap-3 text-ink-700">
          <span class="w-8 h-8 rounded-full bg-ink-900 text-white flex items-center justify-center flex-shrink-0 text-sm">✓</span>
          Analyse TCO personnalisée (Cloud vs On-Premise)
        </li>
        <li class="flex gap-3 text-ink-700">
          <span class="w-8 h-8 rounded-full bg-ink-900 text-white flex items-center justify-center flex-shrink-0 text-sm">✓</span>
          Devis ferme sous 48h ouvrées
        </li>
      </ul>
    </div>

    <form class="glass-strong rounded-3xl p-7 sm:p-9 space-y-5" onsubmit="event.preventDefault(); this.querySelector('#form-ok').classList.remove('hidden'); this.querySelector('button[type=submit]').disabled = true;">
      <div class="grid sm:grid-cols-2 gap-4">
        <label class="block">
          <span class="text-sm font-medium text-ink-700 mb-1.5 block">Nom &amp; prénom</span>
          <input required type="text" class="w-full rounded-xl border border-ink-200/80 bg-white/70 px-4 py-3 text-ink-900 placeholder-ink-400 focus:outline-none focus:border-ink-900 focus:bg-white transition" placeholder="Jean Dupont" />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-ink-700 mb-1.5 block">Email professionnel</span>
          <input required type="email" class="w-full rounded-xl border border-ink-200/80 bg-white/70 px-4 py-3 text-ink-900 placeholder-ink-400 focus:outline-none focus:border-ink-900 focus:bg-white transition" placeholder="jean@entreprise.ch" />
        </label>
      </div>
      <label class="block">
        <span class="text-sm font-medium text-ink-700 mb-1.5 block">Entreprise</span>
        <input required type="text" class="w-full rounded-xl border border-ink-200/80 bg-white/70 px-4 py-3 text-ink-900 placeholder-ink-400 focus:outline-none focus:border-ink-900 focus:bg-white transition" placeholder="ACME Suisse SA" />
      </label>
      <div class="grid sm:grid-cols-2 gap-4">
        <label class="block">
          <span class="text-sm font-medium text-ink-700 mb-1.5 block">Nb de collaborateurs</span>
          <select class="w-full rounded-xl border border-ink-200/80 bg-white/70 px-4 py-3 text-ink-900 focus:outline-none focus:border-ink-900 focus:bg-white transition">
            <option>&lt; 10</option>
            <option>10 – 50</option>
            <option selected>50 – 200</option>
            <option>200+</option>
          </select>
        </label>
        <label class="block">
          <span class="text-sm font-medium text-ink-700 mb-1.5 block">Nb de sites</span>
          <select class="w-full rounded-xl border border-ink-200/80 bg-white/70 px-4 py-3 text-ink-900 focus:outline-none focus:border-ink-900 focus:bg-white transition">
            <option>1</option>
            <option selected>2 – 5</option>
            <option>5+</option>
          </select>
        </label>
      </div>
      <div>
        <span class="text-sm font-medium text-ink-700 mb-2 block">Intérêt</span>
        <div class="grid grid-cols-3 gap-2">
          <label class="flex items-center gap-2 rounded-xl border border-ink-200/80 bg-white/70 px-3 py-2.5 cursor-pointer hover:bg-white transition text-sm">
            <input type="radio" name="interest" class="accent-ink-900"/>Cloud
          </label>
          <label class="flex items-center gap-2 rounded-xl border border-ink-200/80 bg-white/70 px-3 py-2.5 cursor-pointer hover:bg-white transition text-sm">
            <input type="radio" name="interest" class="accent-ink-900"/>On-Prem
          </label>
          <label class="flex items-center gap-2 rounded-xl border border-ink-200/80 bg-white/70 px-3 py-2.5 cursor-pointer hover:bg-white transition text-sm">
            <input type="radio" name="interest" class="accent-ink-900" checked/>À voir
          </label>
        </div>
      </div>
      <label class="block">
        <span class="text-sm font-medium text-ink-700 mb-1.5 block">Quand souhaitez-vous démarrer ?</span>
        <select class="w-full rounded-xl border border-ink-200/80 bg-white/70 px-4 py-3 text-ink-900 focus:outline-none focus:border-ink-900 focus:bg-white transition">
          <option>Immédiatement</option>
          <option selected>1 – 3 mois</option>
          <option>Plus tard</option>
        </select>
      </label>
      <button type="submit" class="btn-primary w-full">Réserver ma démo</button>
      <p id="form-ok" class="hidden text-sm text-emerald-700 bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3">
        Merci ! Un expert vous recontacte sous 24h ouvrées.
      </p>
      <p class="text-xs text-ink-500 text-center">
        Pas de spam, pas d'appel surprise. Vos données sont traitées conformément à la LPD.
      </p>
    </form>
  </div>
</section>
